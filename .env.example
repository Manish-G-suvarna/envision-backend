# Database Configuration
DATABASE_URL="postgresql://postgres:password@localhost:5432/envision_db"

# Server Configuration
PORT=5000
NODE_ENV=development

# Frontend Configuration
FRONTEND_URL="http://localhost:3000"

# Clerk Authentication
CLERK_SECRET_KEY="your-clerk-secret-key"
CLERK_PUBLISHABLE_KEY="your-clerk-publishable-key"

# Redis (for shared rate limiting across multiple instances)
# Get a free Redis from: https://upstash.com or https://redis.com
REDIS_URL="redis://localhost:6379"

# Cloudinary Setup for ID Proof Uploads
CLOUDINARY_CLOUD_NAME="your-cloud-name"
CLOUDINARY_API_KEY="your-api-key"
CLOUDINARY_API_SECRET="your-api-secret"
