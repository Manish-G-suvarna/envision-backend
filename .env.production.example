# --- PRODUCTION ENVIRONMENT TEMPLATE ---
# Copy this to .env on your Hostinger VPS and fill in the values.

# Database (Prisma Accelerate URL)
DATABASE_URL="your-prisma-accelerate-url-here"

# Server Configuration
PORT=5000
NODE_ENV=production

# URLs (Linking Frontend and Backend)
FRONTEND_URL="https://envisionsit.in"
# Recommended additional URLs for local/preview testing:
# ALLOWED_ORIGINS="https://envisionsit.in,https://envision-70i6jic1x-manish-g-suvarnas-projects-b07d8c30.vercel.app"

# Clerk Authentication (Get these from Clerk Dashboard)
CLERK_SECRET_KEY="your-production-clerk-secret-key"
CLERK_PUBLISHABLE_KEY="your-production-clerk-publishable-key"

# JWT Secret for Admin Dashboard
ADMIN_JWT_SECRET="generate-a-long-random-string-here"

# Redis (For Rate Limiting)
REDIS_URL="redis://localhost:6379"

# Cloudinary Setup for ID Proof Uploads
CLOUDINARY_CLOUD_NAME="your-cloudinary-name"
CLOUDINARY_API_KEY="your-cloudinary-api-key"
CLOUDINARY_API_SECRET="your-cloudinary-api-secret"
