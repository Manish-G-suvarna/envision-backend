generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Admin {
  id            Int       @id @default(autoincrement())
  clerk_user_id String?   @unique
  email         String    @unique
  name          String
  password_hash String?
  is_active     Boolean   @default(true)
  last_login_at DateTime?
  created_at    DateTime  @default(now())
  updated_at    DateTime  @updatedAt
}

model Team {
  id           Int        @id @default(autoincrement())
  team_name    String
  created_at   DateTime   @default(now())
  core_members CoreTeam[]
}

model CoreTeam {
  id            Int      @id @default(autoincrement())
  name          String
  role          String
  team_id       Int
  image_url     String?
  display_order Int?     @default(0)
  created_at    DateTime @default(now())
  team          Team     @relation(fields: [team_id], references: [id], onDelete: Cascade)
}

model Department {
  id              Int      @id @default(autoincrement())
  department_name String   @unique
  created_at      DateTime @default(now())
  events          Event[]
}

model Event {
  id            Int               @id @default(autoincrement())
  department_id Int
  event_name    String
  japanese_name String?
  description   String?
  overview      String?
  fee           Decimal           @default(100.00) @db.Decimal(10, 2)
  event_type    EventType
  is_team_event Boolean           @default(false)
  team_min_size Int?
  team_max_size Int?
  is_mega_event Boolean?          @default(false)
  image_url     String?
  day           Int?
  time          String?
  venue         String?
  status        EventStatus       @default(OPEN)
  created_at    DateTime          @default(now())
  department    Department        @relation(fields: [department_id], references: [id], onDelete: Cascade)
  criteria      JudgingCriteria[]
  participants  Participant[]
  rounds        Round[]
  rules         Rule[]
  registrations RegistrationEvent[]
}

model Rule {
  id       Int    @id @default(autoincrement())
  content  String
  event_id Int
  event    Event  @relation(fields: [event_id], references: [id], onDelete: Cascade)
}

model Round {
  id           Int     @id @default(autoincrement())
  round_number Int
  name         String?
  format       String?
  evaluation   String?
  duration     String?
  event_id     Int
  event        Event   @relation(fields: [event_id], references: [id], onDelete: Cascade)
}

model JudgingCriteria {
  id       Int    @id @default(autoincrement())
  content  String
  event_id Int
  event    Event  @relation(fields: [event_id], references: [id], onDelete: Cascade)
}

model Participant {
  id             Int      @id @default(autoincrement())
  event_id       Int
  student_name   String
  email          String
  phone          String?
  college        String?
  payment_proof  String?
  payment_status String   @default("pending")
  amount_paid    Decimal  @default(0.00) @db.Decimal(10, 2)
  registered_at  DateTime @default(now())
  event          Event    @relation(fields: [event_id], references: [id], onDelete: Cascade)
}

model User {
  id           Int      @id @default(autoincrement())
  clerkId      String   @unique
  email        String   @unique
  name         String
  college      String
  branch       String?
  year         String?
  phone        String?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
  department   String?
  id_proof_url String?
  is_onboarded Boolean  @default(false)
  usn          String?  @unique
  env_id       String?  @unique
  gender       String?
  degree       String?
  registrations Registration[]
}

model Registration {
  id             Int                 @id @default(autoincrement())
  user_id        Int
  total_amount   Decimal             @db.Decimal(10, 2)
  payment_status String              @default("pending") // pending, completed, rejected
  utr_id         String?             @unique
  created_at     DateTime            @default(now())
  updated_at     DateTime            @updatedAt
  user           User                @relation(fields: [user_id], references: [id])
  events         RegistrationEvent[]
}

model RegistrationEvent {
  id              Int                  @id @default(autoincrement())
  registration_id Int
  event_id        Int
  team_name       String?
  registration    Registration         @relation(fields: [registration_id], references: [id], onDelete: Cascade)
  event           Event                @relation(fields: [event_id], references: [id])
  members         RegistrationMember[]
}

model RegistrationMember {
  id                    Int               @id @default(autoincrement())
  registration_event_id Int
  user_id               Int?              // Optional if member is not yet registered in Envision
  env_id                String            // Member's ENV ID
  name                  String            // Member's Name (cached from lookup)
  is_leader             Boolean           @default(false)
  registration_event    RegistrationEvent @relation(fields: [registration_event_id], references: [id], onDelete: Cascade)
}

model VerifiedTransaction {
  id         Int      @id @default(autoincrement())
  utr_id     String   @unique
  amount     Decimal  @db.Decimal(10, 2)
  status     String   @default("verified")
  processed  Boolean  @default(false)
  created_at DateTime @default(now())
  updated_at DateTime @updatedAt
}

enum EventType {
  Technical
  Non_Technical @map("Non-Technical")
}

enum EventStatus {
  OPEN
  CLOSED
}
